# API Base URL
VITE_API_BASE_URL=http://localhost:8000

# App Name
VITE_APP_NAME=CollabFoundry

# Environment
VITE_NODE_ENV=development

# Dev auto-login (LOCAL ONLY — only fires when Vite is in DEV).
# Copy to .env.local to skip login/signup/profile-setup on every reload.
# Seeded test users come from backend/seed_dev_users.py.
# VITE_DEV_AUTOLOGIN_USER=ketan
# VITE_DEV_AUTOLOGIN_PASS=DevPass1234
